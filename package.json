{
  "name": "kra-ui",
  "private": true,
  "scripts": {
    "build": "pnpm --filter kra-ui build",
    "dev:example": "pnpm --filter kra-ui-example start",
    "dev:docs": "pnpm --filter kra-ui-docs dev",
    "build:docs": "pnpm --filter kra-ui-docs build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "typescript": "~5.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.15.4"
}
