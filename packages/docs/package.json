{
  "name": "kra-ui-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check:astro-bootstrap": "node scripts/check-astro-bootstrap.mjs",
    "check:demo-registry": "node scripts/check-demo-registry.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:legacy": "node scripts/check-legacy.mjs",
    "check:redirects": "node scripts/check-redirects.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:smoke": "node scripts/check-smoke.mjs --scope full",
    "check:smoke:core": "node scripts/check-smoke.mjs --scope core-pages",
    "check:smoke:risky": "node scripts/check-smoke.mjs --scope risky-demos",
    "check:release": "pnpm run check:legacy && pnpm run check:smoke && pnpm run check:redirects && pnpm run check:seo",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "verify:release": "pnpm run typecheck && pnpm run build && pnpm run check:release",
    "deploy:prod": "pnpm run verify:release && pnpm exec wrangler deploy",
    "rollback:prod": "node scripts/rollback-prod.mjs",
    "typegen": "astro sync",
    "typecheck": "pnpm run typegen && astro check",
    "validate:nav": "echo \"skip legacy docs-nav validation on Astro stack\"",
    "clean": "rm -rf dist .astro"
  },
  "dependencies": {
    "isbot": "^5.1.32",
    "kra-ui": "workspace:^",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-native-web": "^0.21.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^5.0.2",
    "@cloudflare/vite-plugin": "^1.29.1",
    "@shikijs/primitive": "^4.0.2",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "astro": "^5.5.2",
    "typescript": "~5.3.3",
    "vite": "^6.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.23.0"
  }
}
