{
  "name": "kra-ui-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate": "node scripts/generate-docs-routes.mjs",
    "check:astro-bootstrap": "node scripts/check-astro-bootstrap.mjs",
    "check:demo-registry": "node scripts/check-demo-registry.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:legacy": "node scripts/check-legacy.mjs",
    "check:redirects": "node scripts/check-redirects.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:smoke": "node scripts/check-smoke.mjs",
    "predev": "pnpm run generate",
    "prebuild": "pnpm run generate",
    "dev": "astro dev",
    "build": "pnpm run validate:nav && astro build",
    "preview": "astro preview",
    "typegen": "astro sync",
    "typecheck": "pnpm run typegen && astro check",
    "validate:nav": "node scripts/validate-docs-nav.mjs",
    "test:scripts": "node --test scripts/path-to-route.test.mjs",
    "clean": "node scripts/generate-docs-routes.mjs --clean-only && rm -rf dist .astro"
  },
  "dependencies": {
    "isbot": "^5.1.32",
    "kra-ui": "workspace:^",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@cloudflare/vite-plugin": "^1.29.1",
    "@react-router/dev": "^7.13.1",
    "@react-router/fs-routes": "^7.13.1",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "astro": "^5.5.2",
    "typescript": "~5.3.3",
    "vite": "^6.3.0",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.23.0"
  }
}
