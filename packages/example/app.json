{
  "expo": {
    "name": "NativeUI Example",
    "slug": "kra-ui-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kra-ui-example",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "bundleIdentifier": "com.nativeui.example",
      "supportsTablet": true
    },
    "android": {
      "package": "com.nativeui.example",
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
