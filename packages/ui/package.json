{
  "name": "kra-ui",
  "version": "0.8.1",
  "description": "基于 @shopify/restyle 的 React Native UI 组件库",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "homepage": "https://github.com/aafnnp/kra-ui",
  "repository": {
    "type": "git",
    "url": "https://github.com/aafnnp/kra-ui.git"
  },
  "bugs": {
    "url": "https://github.com/aafnnp/kra-ui/issues"
  },
  "author": "aafnnp",
  "files": [
    "src",
    "lib",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "rm -rf lib",
    "lint": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "bob build",
    "prepack": "cp ../../README.md ."
  },
  "keywords": [
    "react-native",
    "ui",
    "restyle",
    "theme",
    "components"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "peerDependencies": {
    "@shopify/restyle": ">=2.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=13.0.0"
  },
  "devDependencies": {
    "@shopify/restyle": "^2.4.4",
    "@types/react": "~18.3.28",
    "@types/jest": "^29.5.14",
    "react": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "react-native": "^0.76.0",
    "react-native-builder-bob": "^0.30.0",
    "react-native-reanimated": "^3.16.7",
    "react-native-svg": "^15.11.2",
    "@testing-library/react-native": "^13.3.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.3.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
